# Environment Variables for Mama Onyinye LandMark
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@mamaonyinye.com
ADMIN_EMAIL=admin@mamaonyinye.com

# WhatsApp (International format, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=2348000000000

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://maps.google.com/maps?q=V94W%2BP6Q,+University+Rd,+Nsukka&output=embed

# Site URL
NEXT_PUBLIC_SITE_URL=https://mamaonyinye.com
